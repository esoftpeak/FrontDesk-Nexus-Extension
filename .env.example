# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: Edge Function that accepts POST JSON { front_image_base64, back_image_base64 }
# Authorization: Bearer <user access token> (extension sends JWT)
VITE_OCR_FUNCTION_URL=

# Optional: remote JSON { "minVersion": "1.0.0" } — blocks automation when extension is older
VITE_MIN_EXTENSION_VERSION_CHECK_URL=
