# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: remote JSON { "minVersion": "1.0.0" } — blocks automation when extension is older
VITE_MIN_EXTENSION_VERSION_CHECK_URL=

# Comma-separated `externally_connectable.matches` entries (origin + path; use /* for all paths on that host).
# https://front-desk-nexus.vercel.app/* is included in the manifest by default; add more hosts here if needed.
# VITE_PORTAL_EXTERN_MATCHES=https://another-domain.example.com/*
