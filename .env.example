# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: remote JSON { "minVersion": "1.0.0" } — blocks automation when extension is older
VITE_MIN_EXTENSION_VERSION_CHECK_URL=

# Comma-separated `externally_connectable.matches` entries (origin + path; use /* for all paths on that host).
# Default manifest already includes localhost:5173. Production example:
VITE_PORTAL_EXTERN_MATCHES=https://front-desk-nexus.vercel.app/*
